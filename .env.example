# IPIS environment variables — copy to .env and fill in
# DO NOT commit the actual .env file

# ---------- Database ----------
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=ipis
INFLUXDB_BUCKET=process_data

# ---------- MQTT ----------
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ---------- OPC-UA ----------
OPCUA_SERVER_ENDPOINT=opc.tcp://localhost:4840
OPCUA_NAMESPACE=ipis

# ---------- MLflow ----------
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=ipis-module1

# ---------- FastAPI ----------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ---------- Streamlit ----------
STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8501

# ---------- DWSIM ----------
DWSIM_PATH=/opt/DWSIM
# Windows example:
# DWSIM_PATH=C:\Program Files\DWSIM8

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---------- Dev only ----------
DEBUG=false
